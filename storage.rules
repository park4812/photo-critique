rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /photos/{photoId}/{allPaths=**} {
      // Anyone can read photos
      allow read: if true;
      // Anyone can upload (add auth later: request.auth != null)
      allow write: if request.resource.size < 10 * 1024 * 1024 // Max 10MB
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
